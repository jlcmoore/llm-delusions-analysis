# Copy to .env and fill with your local values.

# Vertex Batch (required for Vertex AI batch jobs)
GCS_BUCKET_NAME="my-batch-bucket"
GCS_PATH_SERVICE_ACCOUNT="/path/to/service_account.json"
GOOGLE_APPLICATION_CREDENTIALS="/path/to/service_account.json"
VERTEXAI_PROJECT="gse-social"
VERTEXAI_LOCATION="global"

# OpenAI / Azure OpenAI
OPENAI_API_KEY="sk-..."

# Anthropic
ANTHROPIC_API_KEY=""

# Together
TOGETHER_API_KEY=""

